# ============================================================
# BugTriage OpenEnv — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── LLM API (required for inference.py) ─────────────────────
# Your HuggingFace token or compatible API key
HF_TOKEN=hf_your_token_here

# LLM API base URL (HuggingFace router or any OpenAI-compatible endpoint)
API_BASE_URL=https://router.huggingface.co/v1

# Model identifier
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# ── Environment server URL (used by inference.py) ────────────
# URL where the BugTriage server is running
# For local development:
ENV_URL=http://localhost:7860
# For deployed HF Space:
# ENV_URL=https://your-space-name.hf.space

# ── Server config (optional) ─────────────────────────────────
# Port for local development (default: 7860 for HF Space compatibility)
PORT=7860
HOST=0.0.0.0
# Set to "true" to enable hot-reload during development
RELOAD=false
